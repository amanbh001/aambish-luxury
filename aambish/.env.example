# .env.local — Copy this to .env.local and fill in your values
# Never commit the actual .env.local file to version control

# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://aambish.com

# ─── Database ───────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/aambish?retryWrites=true&w=majority

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long

# ─── Email (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@aambish.com
SMTP_PASS=your_app_password_here
CONTACT_EMAIL=hello@aambish.com

# ─── Cloudinary ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay ───────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX

# ─── Analytics & Ads ────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXXX
